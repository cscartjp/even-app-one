# G2 Hermes Bridge Server — 環境変数サンプル
# 実値は .env にコピーして使う:  cp env.example .env
# （.env はリポジトリ root の .gitignore で除外済み）

# Bridge Server の待ち受けポート
PORT=8787

# listen するホスト（任意・既定 0.0.0.0）。
# 多層防御（Phase 8）: bearerless の /audio/<id> を他インターフェースから守るため、
# 本番は Tailscale インターフェースの IP を設定してその IF だけで待ち受ける
# （例: BIND_HOST=100.x.x.x）。or OS firewall で他 IF からの :PORT を遮断する。
# BIND_HOST=0.0.0.0

# G2 クライアント（WebView）→ Bridge の Bearer 認証トークン。
# 本番は 32 文字以上のランダム値にする（仕様書 §11）。
BRIDGE_TOKEN=dev-token

# Hermes Agent API Server のベース URL（/v1 まで）。
# Hermes が同じ Mac なら 127.0.0.1。別 Mac の場合は SSH トンネル
# （ssh -L 8642:127.0.0.1:8642 <host>）でこの 127.0.0.1 を維持するか、
# Tailscale IP（http://100.x.x.x:8642/v1）を直接指定する。
HERMES_BASE_URL=http://127.0.0.1:8642/v1

# Hermes API Server の API キー。change-me-local-dev のままにしない（仕様書 §11 / Plans 制約）。
# このキーは Mac の .env のみに置き、WebView には絶対に渡さない。
HERMES_API_KEY=change-me-local-dev

# Bridge→Hermes ask fetch のタイムアウト（ms・任意、既定 180000）。
# Hermes エージェントは住所/評価などの lookup で生成が伸びるため長め（実測 ~115s 例あり・グラスは待てる）。
# 超過で /v1/ask は 504 を返し、G2 を無限「Thinking…」にしない（仕様書のリスク2）。
# /health の到達性プローブには使わない（短い固定値で確認）。
HERMES_TIMEOUT_MS=180000

# CORS で許可する Origin（カンマ区切り・任意）。未設定なら全 origin を反映（Phase 1 既定）。
# 実機 WebView の Origin を Task 1.5 で採取したら、その full origin を設定して締める（仕様書 §15.1）。
# 例: CORS_ALLOWED_ORIGINS=http://100.65.114.98:8787
# CORS_ALLOWED_ORIGINS=

# --- Phase 3 音声入力（STT サイドカー）---

# STT サイドカーのベース URL（loopback・/transcribe は含めない・任意、既定 http://127.0.0.1:8643）。
# サイドカーは Mac B の 127.0.0.1 のみで待ち受け、Bridge だけが叩く（仕様書 §4.1）。
STT_BASE_URL=http://127.0.0.1:8643

# Bridge→STT fetch のタイムアウト（ms・任意、既定 60000）。STT は重いため Hermes より長め。
# 超過で /v1/transcribe は 504 を返す（仕様書 §4.2）。
STT_TIMEOUT_MS=60000

# /v1/transcribe の WAV ボディ上限（bytes・任意、既定 2097152=2MB）。
# 16kHz/16bit mono の 30s 録音 ≒ 約960KB に対する安全天井。超過で 413（仕様書 §4.2）。
TRANSCRIBE_MAX_BYTES=2097152

# --- Phase 8 音声回答（AivisSpeech WAV + audioUrl）---
# 音声生成は Bridge が AivisSpeech Engine（VOICEVOX 互換）を loopback で直接叩く独立実装。
# 設定 OFF（既定）のとき ask は tts を付けず、ここの変数は一切使われない（現行等価）。

# AivisSpeech Engine のベース URL（loopback・既定 http://127.0.0.1:10101）。
AIVIS_BASE_URL=http://127.0.0.1:10101

# 話者 ID（既定 まお／ノーマル 888753760。888753761〜888753764 で style 変更可）。
AIVIS_SPEAKER_ID=888753760

# 合成タイムアウト（ms・任意）。/audio_query 5s / /synthesis 15s / 全体 abort 20s（実測ベース）。
# 超過は型付きエラー→audioUrl:null に降格しテキスト回答は 200 で返す。
AIVIS_QUERY_TIMEOUT_MS=5000
AIVIS_SYNTHESIS_TIMEOUT_MS=15000
AIVIS_ABORT_TIMEOUT_MS=20000

# 読み上げ対象の最大文字数（任意・既定 300）。超過は切り詰め（長文 WAV 肥大回避）。
TTS_MAX_CHARS=300

# Aivis /synthesis の同時実行上限（任意・既定 2。重いため絞る）。
TTS_MAX_CONCURRENCY=2

# 生成 WAV の in-memory キャッシュ上限（任意）。TTL 秒 / 件数 / 総 byte の三重で古い順 evict。
AUDIO_TTL_SECONDS=300
AUDIO_MAX_ENTRIES=100
AUDIO_MAX_BYTES=209715200
